# Server-side only — used by Next.js rewrite proxy (never sent to browser)
# Set this in .env.local for local dev; set API_URL secret in Vercel for production
API_URL=http://localhost:8000

# Browser-visible WebSocket URL (must be publicly reachable)
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── Analytics ─────────────────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID (get from analytics.google.com)
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# ── IndexNow (instant search engine indexing) ─────────────────────────────────
# Generate: python -c "import uuid; print(uuid.uuid4().hex)"
# Must match INDEXNOW_KEY set on the backend
INDEXNOW_KEY=
