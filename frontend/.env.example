# Server-side only — used by Next.js rewrite proxy (never sent to browser)
# Set this in .env.local for local dev; set API_URL secret in Vercel for production
API_URL=http://localhost:8000

# Browser-visible WebSocket URL (must be publicly reachable)
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── Analytics ─────────────────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID (get from analytics.google.com)
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# ── IndexNow (instant search engine indexing) ─────────────────────────────────
# 1. Generate a key: python -c "import uuid; print(uuid.uuid4().hex)"
# 2. Set INDEXNOW_KEY to that value here
# 3. Create /public/[key].txt containing just the key on one line
# 4. Set INDEXNOW_PING_TOKEN to a secret for protecting the /api/indexnow endpoint
# 5. After deploy, call: GET https://pricebasket.in/api/indexnow?token=YOUR_PING_TOKEN
INDEXNOW_KEY=
INDEXNOW_PING_TOKEN=

# ── Google Search Console / SEO ───────────────────────────────────────────────
# Site verification meta tag value (from Google Search Console → HTML tag method)
# Format: the content= value only, e.g. "abc123xyz"
NEXT_PUBLIC_GSC_VERIFICATION=

# ── Social / OG ───────────────────────────────────────────────────────────────
# Used for Twitter card meta tags
NEXT_PUBLIC_TWITTER_HANDLE=@pricebasketin
