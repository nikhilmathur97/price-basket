<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Config
  - Only allows HTTPS for all connections (no cleartext HTTP)
  - pricebasket.in is always HTTPS so this is fine
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
