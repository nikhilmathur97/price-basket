APP_ENV=production
DEBUG=false
SECRET_KEY=REPLACE_WITH_STRONG_SECRET_64_CHARS
ALLOWED_ORIGINS=https://pricebasket.in,https://www.pricebasket.in

DATABASE_URL=postgresql+asyncpg://pricebasket:PASSWORD@127.0.0.1:5432/pricebasket_db

REDIS_URL=rediss://default:PASSWORD@HOST:PORT/0
CELERY_BROKER_URL=rediss://default:PASSWORD@HOST:PORT/1
CELERY_RESULT_BACKEND=rediss://default:PASSWORD@HOST:PORT/2

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

SENTRY_DSN=
PROMETHEUS_ENABLED=true

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

APIFY_API_TOKEN=

# ── Admin bootstrap ────────────────────────────────────────────────────────────
# Set a strong random string — used for one-time admin creation via POST /admin/bootstrap
ADMIN_SETUP_KEY=
SEED_SECRET=

# ── Marketing / SEO Automation ─────────────────────────────────────────────────
# Public site URL (used to build canonical links in generated content + social posts)
SITE_URL=https://pricebasket.in

# Master switches — set both to true to activate daily content + social posting
CONTENT_AUTOMATION_ENABLED=true
SOCIAL_AUTOMATION_ENABLED=true

# IndexNow key — instant Google/Bing indexing on every new blog post
# Generate: python -c "import uuid; print(uuid.uuid4().hex)"
INDEXNOW_KEY=

# ── Telegram (easiest channel — fully automatable, no approval needed) ─────────
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Add the bot as admin to your channel
# 3. Set TELEGRAM_CHANNEL_ID to your channel handle e.g. @PriceBasketDeals
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=@PriceBasketDeals

# ── Meta (Facebook Page + Instagram Business) ──────────────────────────────────
# 1. Go to developers.facebook.com → My Apps → Create App → Business
# 2. Add "Instagram Graph API" + "Pages API" products
# 3. Generate a Page Access Token (never-expiring) from Graph API Explorer
# 4. FACEBOOK_PAGE_ID: your FB Page numeric ID (found in Page Settings → About)
# 5. INSTAGRAM_ACCOUNT_ID: your IG Business account numeric ID
META_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
INSTAGRAM_ACCOUNT_ID=

# ── X / Twitter ────────────────────────────────────────────────────────────────
# 1. Go to developer.twitter.com → Projects & Apps → Create App
# 2. Enable OAuth 1.0a with Read+Write permissions
# 3. Generate Access Token & Secret under "Keys and Tokens"
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ── WhatsApp Business Cloud API ────────────────────────────────────────────────
# 1. Go to developers.facebook.com → Create App → Business → WhatsApp
# 2. Get Phone Number ID and a permanent System User Access Token
# Note: Broadcasting requires pre-approved message templates + opt-in subscriber list
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
