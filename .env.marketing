# ════════════════════════════════════════════════════════════
#  PRICEBASKET MARKETING CREDENTIALS VAULT v3.0
#  All keys managed from Admin → Marketing → Settings
#  Never commit this file. Add to .gitignore.
# ════════════════════════════════════════════════════════════

# ── ACTIVE AI PROVIDER ──────────────────────────────────────
# Options: gemini | auto
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash-latest

# ── IMAGE / CREATIVE AI ──────────────────────────────────────
# Stability AI — free 25 credits/month at platform.stability.ai
STABILITY_AI_KEY=
STABILITY_ENGINE=stable-diffusion-xl-1024-v1-0

# Pollinations.ai — 100% FREE, no key needed
POLLINATIONS_ENABLED=true

# ── TWITTER / X ──────────────────────────────────────────────
# Already set in backend/.env — copied here for marketing module
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=

# ── REDDIT ───────────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=pricebasket_in
REDDIT_PASSWORD=
REDDIT_USER_AGENT=PriceBasketAgent/3.0 by /u/pricebasket_in

# ── LINKEDIN ─────────────────────────────────────────────────
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_ID=
LINKEDIN_PERSON_URN=

# ── WHATSAPP BUSINESS API ─────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ── MEDIUM BLOG ───────────────────────────────────────────────
MEDIUM_INTEGRATION_TOKEN=
MEDIUM_AUTHOR_ID=

# ── EMAIL / SMTP ──────────────────────────────────────────────
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_NAME=PriceBasket Team

# ── ONESIGNAL PUSH ────────────────────────────────────────────
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# ── BRAND CONFIG ──────────────────────────────────────────────
BRAND_NAME=PriceBasket
