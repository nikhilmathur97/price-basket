# ============================================================
# PRICEBASKET.IN — AI Agent Traffic System
# Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it's in .gitignore
# Rotate all keys every 90 days.
# ============================================================

# ── AI / Claude — pick ONE option ────────────────────────────
# Option A: Anthropic direct
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Option B: Amazon Bedrock (use this if you already have AWS)
# Requires Claude models enabled in your AWS account:
#   AWS Console → Bedrock → Model access → Enable Claude 3.5 Sonnet
# Create IAM user with AmazonBedrockFullAccess (or scoped policy)
# Region us-east-1 has the widest Claude model availability
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Bedrock model used: anthropic.claude-3-5-sonnet-20241022-v2:0
# If both keys are set, Bedrock takes priority over ANTHROPIC_API_KEY

# ── Twitter / X ──────────────────────────────────────────────
# Get from: https://developer.twitter.com/en/portal/dashboard
# Requires: Elevated access + OAuth 1.0a User Context
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_USERNAME=pricebasketin

# ── Instagram / Meta Graph API ────────────────────────────────
# Get from: https://developers.facebook.com/apps/
# Requires: Instagram Business Account linked to Facebook Page
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
META_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# ── WhatsApp Business Cloud API ───────────────────────────────
# Get from: https://developers.facebook.com/apps/ → WhatsApp
# Requires: WhatsApp Business Account + approved message templates
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# Template names (must be approved in Meta Business Manager)
WHATSAPP_TEMPLATE_NAME=price_drop_alert
WHATSAPP_TEMPLATE_LANG=en

# ── Email (Brevo / Sendinblue) ────────────────────────────────
# Get from: https://app.brevo.com/settings/keys/api
# Free tier: 300 emails/day
BREVO_API_KEY=

# ── Reddit ────────────────────────────────────────────────────
# Get from: https://www.reddit.com/prefs/apps → Create App
# Type: script
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# ── Browser Push Notifications (VAPID) ───────────────────────
# Generate keys:
#   python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print('PRIVATE:', v.private_key); print('PUBLIC:', v.public_key)"
# Also set NEXT_PUBLIC_VAPID_PUBLIC_KEY in frontend .env
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=mailto:admin@pricebasket.in

# ── Google APIs ───────────────────────────────────────────────
# Service account JSON path (used for GSC + GA4 + Indexing API)
# Create at: https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_SERVICE_ACCOUNT_FILE=growth/credentials/google-service-account.json
GSC_SERVICE_ACCOUNT_JSON=growth/credentials/google-service-account.json

# Google Search Console
# Get from: https://search.google.com/search-console/
GSC_SITE_URL=https://pricebasket.in

# Google Analytics 4
# Get from: GA4 Admin → Property Settings → Property ID
GA4_PROPERTY_ID=

# IndexNow (instant indexing for Bing/Yandex/Google)
# Generate any GUID: python -c "import uuid; print(uuid.uuid4().hex)"
# Also set in frontend .env as NEXT_PUBLIC_INDEXNOW_KEY
INDEXNOW_KEY=

# Google PageSpeed / General API key
GOOGLE_API_KEY=

# ── Buffer (Instagram scheduling) ────────────────────────────
# Get from: https://buffer.com/developers/api
BUFFER_ACCESS_TOKEN=

# ── Backend API ───────────────────────────────────────────────
BACKEND_API_URL=https://pricebasket-api.onrender.com

# ── Agent settings ────────────────────────────────────────────
# Set to "true" to run all agents in dry-run mode (no actual posts)
AGENT_DRY_RUN=false

# Maximum tweets per day (Twitter limit: 300/day)
TWITTER_MAX_TWEETS_PER_DAY=5

# Maximum Instagram posts per day (Meta limit: 25/day)
INSTAGRAM_MAX_POSTS_PER_DAY=3

# Claude max tokens for social posts (cost control)
CLAUDE_MAX_TOKENS_SOCIAL=600
CLAUDE_MAX_TOKENS_BLOG=2000

# Reddit: max answers per session
REDDIT_MAX_ANSWERS_PER_SESSION=2

# ── Notification settings ─────────────────────────────────────
# Admin email for weekly SEO reports
ADMIN_EMAIL=admin@pricebasket.in

# ── Traffic Flow Agent ───────────────────────────────────────
# Active-user goal (triggers multi-channel burst when below this)
TRAFFIC_GOAL_ACTIVE_USERS=100
# Monitoring window in minutes (matches backend live-visitor window)
TRAFFIC_MONITOR_WINDOW_MIN=30
# Minimum minutes between bursts (avoid channel spam)
BURST_COOLDOWN_MIN=45

# ── Site ──────────────────────────────────────────────────────
SITE_URL=https://pricebasket.in
